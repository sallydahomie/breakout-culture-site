# Copy this file to .env.local and fill in your own Stripe TEST MODE secret key.
# .env.local is gitignored and should never be committed.
# Get a test key at https://dashboard.stripe.com/test/apikeys (it starts with sk_test_...)
# Never put a live secret key (sk_live_...) here.
STRIPE_SECRET_KEY=

# Mailchimp — powers the "Notify Me!" restock signup forms on the shop page.
# API key: Mailchimp account > Profile > Extras > API keys (looks like
#   abc123def456...-us21 — the "-us21" suffix is your data center, read
#   automatically from the key, no need to set it separately).
MAILCHIMP_API_KEY=
# Audience/list ID: Audience > Settings > Audience name and defaults > Audience ID
MAILCHIMP_AUDIENCE_ID=
